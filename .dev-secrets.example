# Copy to `.dev-secrets.env` (local only, gitignored) and fill values.
CP_STAGING_DEV_AUTH_SECRET='replace-with-staging-dev-auth-secret'
CP_STAGING_DEV_USER='replace-with-user-id'

# Usage:
#   set -a; source .dev-secrets.env; set +a
#   curl -H "X-Dev-User: $CP_STAGING_DEV_USER" \
#        -H "X-Dev-Secret: $CP_STAGING_DEV_AUTH_SECRET" \
#        https://cp.staging.chatcode.dev/auth/me
