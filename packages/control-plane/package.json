{
  "name": "@chatcode/control-plane",
  "version": "0.1.0",
  "private": true,
  "description": "Chatcode control plane – Cloudflare Workers + Durable Objects + D1",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "migrate": "wrangler d1 execute chatcode --local --file=src/db/migrations/0001_initial.sql",
    "migrate:remote": "wrangler d1 execute chatcode --remote --file=src/db/migrations/0001_initial.sql",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@chatcode/protocol": "workspace:*",
    "nanoid": "^5.1.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.19",
    "@cloudflare/workers-types": "^4.20260305.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.70.0"
  }
}
